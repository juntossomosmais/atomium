{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "experimentalDecorators": true,
    "lib": ["dom", "es2022"],
    "declaration": true,
    "rootDir": "src",
    "outDir": "../core/react/dist",
    "moduleResolution": "Bundler",
    "module": "esnext",
    "target": "es2022",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react",
    "skipLibCheck": true,
    "paths": {
      "@juntossomosmais/atomium": ["../core/dist/types/index.d.ts"],
      "@juntossomosmais/atomium/dist/components": ["../core/dist/components/index.d.ts"],
      "@juntossomosmais/atomium/dist/components/*": ["../core/dist/components/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
