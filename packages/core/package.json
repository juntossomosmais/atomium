{
  "name": "@juntossomosmais/atomium",
  "version": "4.3.0",
  "description": "Core of web components for Atomium",
  "repository": {
    "type": "git",
    "url": "https://github.com/juntossomosmais/atomium.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "@juntossomosmais:registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/core/core.esm.js",
  "files": [
    "dist/",
    "hydrate/",
    "loader/",
    "react/",
    "vue/",
    "core.css"
  ],
  "scripts": {
    "build": "stencil build && npx copyfiles --flat ./dist/core/core.css ./ && node -e \"require('fs').writeFileSync('dist/components/package.json', JSON.stringify({ type: 'module' }, null, 2) + '\\n')\" && node scripts/ssr-smoke.mjs",
    "start": "stencil build --watch",
    "test": "stencil test --spec",
    "test:ci": "stencil test --spec --coverage --no-cache --updateSnapshot --ci",
    "test:watch": "stencil test --spec",
    "generate": "stencil generate",
    "prebuild": "node -e \"const fs = require('fs'); fs.mkdirSync('react', { recursive: true }); fs.mkdirSync('vue', { recursive: true }); fs.writeFileSync('core.css', '')\"",
    "publish-library": "npm publish --access public",
    "publish-library-alpha": "npm publish --access public --tag alpha"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./dist/components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./dist/*": "./dist/*",
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js"
    },
    "./react": {
      "types": "./react/dist/index.d.ts",
      "import": "./react/dist/index.js"
    },
    "./react/next": {
      "types": "./react/dist/index.server.d.ts",
      "import": "./react/dist/index.server.js"
    },
    "./vue": {
      "types": "./vue/dist/index.d.ts",
      "import": "./vue/dist/index.js"
    },
    "./core.css": {
      "import": "./core.css",
      "require": "./core.css"
    }
  },
  "dependencies": {
    "@stencil/react-output-target": "^1.5.3",
    "@stencil/vue-output-target": "^0.13.2"
  },
  "devDependencies": {
    "@atomium/scss-utils": "workspace:*",
    "@atomium/storybook-utils": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vue": ">=3.4.38"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "build",
          {
            "projects": [
              "@juntossomosmais/atomium-icons",
              "@juntossomosmais/atomium-tokens"
            ],
            "target": "build"
          }
        ],
        "outputs": [
          "{projectRoot}/dist",
          "{projectRoot}/hydrate",
          "{projectRoot}/loader",
          "{projectRoot}/core.css",
          "{projectRoot}/src/components.d.ts",
          "{workspaceRoot}/packages/react/src/components",
          "{workspaceRoot}/packages/vue/src/components"
        ]
      },
      "start": {
        "dependsOn": [
          "build"
        ]
      },
      "publish-library": {
        "dependsOn": [
          "build",
          {
            "projects": [
              "@juntossomosmais/atomium-react",
              "@juntossomosmais/atomium-vue"
            ],
            "target": "build"
          }
        ]
      }
    }
  }
}
