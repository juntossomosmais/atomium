{
  "name": "@juntossomosmais/atomium-vue",
  "description": "Vue transpiled for Atomium",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "tsc -p . --watch",
    "build": "npm run compile && npm run copy",
    "compile": "tsc --outDir ../core/vue/dist --declarationDir ../core/vue/dist/types",
    "copy": "npx copyfiles --flat ./package.json ../core/vue"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          {
            "projects": [
              "@juntossomosmais/atomium"
            ],
            "target": "build"
          }
        ],
        "outputs": [
          "{workspaceRoot}/packages/core/vue"
        ]
      },
      "start": {
        "dependsOn": [
          {
            "projects": [
              "@juntossomosmais/atomium"
            ],
            "target": "build"
          }
        ]
      }
    }
  },
  "devDependencies": {
    "@juntossomosmais/atomium": "workspace:*"
  }
}
