{
  "name": "@juntossomosmais/atomium-vue",
  "description": "Vue transpiled for Atomium",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "tsc -p . --watch",
    "build": "npm run compile && npm run copy",
    "compile": "tsc -p tsconfig.json",
    "copy": "npx copyfiles --flat ./package.json ../core/vue"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          {
            "projects": [
              "@juntossomosmais/atomium"
            ],
            "target": "build"
          }
        ],
        "outputs": [
          "{workspaceRoot}/packages/core/vue"
        ]
      },
      "start": {
        "dependsOn": [
          {
            "projects": [
              "@juntossomosmais/atomium"
            ],
            "target": "build"
          }
        ]
      }
    }
  },
  "dependencies": {
    "@stencil/vue-output-target": "^0.13.2"
  },
  "devDependencies": {
    "@juntossomosmais/atomium": "workspace:*",
    "vue": "^3.5.33"
  },
  "peerDependencies": {
    "vue": ">=3.4.38"
  }
}
